{
  "name": "@setemiojo/oxlint-config",
  "version": "0.1.0",
  "description": "Shareable OXC toolchain config for oxlint and oxfmt",
  "homepage": "https://github.com/Oluwasetemi/oxc-config",
  "license": "MIT",
  "author": "Oluwasetemi Ojo <setemiojo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oluwasetemi/oxc-config.git"
  },
  "bin": {
    "oxlint-config": "./bin/index.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./oxfmt": {
      "types": "./dist/oxfmt.d.mts",
      "default": "./dist/oxfmt.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run typegen && pnpm run versiongen && tsdown",
    "lint": "oxlint . --ignore-pattern test/fixtures/input --ignore-pattern _fixtures",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "typegen": "tsx scripts/typegen.ts",
    "versiongen": "tsx scripts/versiongen.ts",
    "gen": "nr typegen && nr versiongen",
    "bump": "bumpp",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "local-pkg": "^1.1.2"
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "execa": "^9.6.1",
    "nano-staged": "^1.0.2",
    "oxlint": "^1.62.0",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "tsdown": "^0.21.10",
    "tsnapi": "^0.3.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@tanstack/eslint-plugin-router": "*",
    "oxfmt": "*",
    "oxlint": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/eslint-plugin-router": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "!(test/fixtures/input/**)*.{ts,tsx,js,jsx}": "oxlint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
